# ============================================
# VibePaper 环境配置文件
# ============================================

# ============================================
# AI 提供商配置
# ============================================
# 选择AI提供商: zhipu 或 anthropic
AI_PROVIDER=zhipu

# --------------------------------------------
# 智谱AI (Zhipu AI / BigModel) 配置
# --------------------------------------------
# 获取API Key: https://open.bigmodel.cn/usercenter/apikeys
ZHIPU_API_KEY=your_zhipu_api_key_here

# 智谱AI模型选择 (可选)
# glm-4-plus: 最强性能，适合复杂任务
# glm-4: 标准版，平衡性能和速度
# glm-4-air: 轻量快速，适合一般任务
# glm-4-flash: 超高速，适合简单任务
# glm-3-turbo: 经济版，成本最低
ZHIPU_MODEL=glm-4

# API端点 (通常不需要修改)
ZHIPU_BASE_URL=https://open.bigmodel.cn/api/paas/v4

# --------------------------------------------
# Anthropic Claude 配置 (可选)
# --------------------------------------------
# 如果要使用Claude，设置 AI_PROVIDER=anthropic 并填写以下内容
# 获取API Key: https://console.anthropic.com/
# ANTHROPIC_API_KEY=your_anthropic_api_key_here
# ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

# ============================================
# 应用配置
# ============================================
# NextAuth 密钥 (用于后续认证功能)
# 生成方法: openssl rand -base64 32
NEXTAUTH_SECRET=your_nextauth_secret_here

# 应用URL (开发环境通常不需要修改)
NEXTAUTH_URL=http://localhost:3000

# ============================================
# 使用说明
# ============================================
# 1. 复制此文件为 .env.local
# 2. 填写你的智谱AI API Key
# 3. 运行 npm run dev 启动开发服务器
